<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Status Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_card"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:gravity="start">

                    <TextView
                        android:id="@+id/voskStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/badge_vosk_loading"
                        android:textSize="12sp"
                        android:textColor="@color/badge_pending_text"
                        android:background="@drawable/badge_bg_pending"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                    <TextView
                        android:id="@+id/llmStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/badge_llm_none"
                        android:textSize="12sp"
                        android:textColor="@color/badge_pending_text"
                        android:background="@drawable/badge_bg_pending"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/preparing"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_secondary"
                    android:lineSpacingExtra="2dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="10dp"
                    android:indeterminate="true"
                    android:progressTint="@color/primary"
                    android:indeterminateTint="@color/primary"
                    android:visibility="visible" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Record Hero ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="28dp"
                android:paddingBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <FrameLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center">

                    <View
                        android:id="@+id/pulseRing"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_record_ring"
                        android:alpha="0" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRecord"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:enabled="false"
                        app:icon="@android:drawable/ic_btn_speak_now"
                        app:iconSize="36dp"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="40dp"
                        app:backgroundTint="@color/primary" />
                </FrameLayout>

                <TextView
                    android:id="@+id/recordHintText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/record_hint"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Secondary Actions Row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUploadAudio"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/upload_audio"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLoadModel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/load_llm_model"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/primary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadModel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="14dp"
            android:text="@string/download_model"
            android:textSize="13sp"
            app:icon="@android:drawable/stat_sys_download"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/primary_dark" />

        <!-- ── Transcription Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="@color/primary"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/transcription_label"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/transcriptionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="90dp"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:lineSpacingExtra="5dp"
                    android:hint="यहाँ ट्रांसक्रिप्शन दिखेगा…"
                    android:textColorHint="@color/on_surface_secondary"
                    android:scrollbars="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Process Button ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProcess"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="10dp"
            android:text="🤖  AI से प्रोसेस करें  →"
            android:textSize="16sp"
            android:enabled="false"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/primary" />

        <!-- ── Clear Button ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="@string/clear"
            android:textColor="@color/error"
            android:visibility="gone"
            app:cornerRadius="12dp"
            app:strokeColor="@color/error" />

    </LinearLayout>
</ScrollView>

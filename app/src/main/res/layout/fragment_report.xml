<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:animateLayoutChanges="true">

        <!-- ── Report Header Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_gradient_header"
                android:paddingTop="28dp"
                android:paddingBottom="28dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="36sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Medical Report"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="AI-Generated • On-Device"
                    android:textSize="13sp"
                    android:textColor="#B3FFFFFF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Processing Indicator ── -->
        <LinearLayout
            android:id="@+id/processingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:visibility="visible">

            <ProgressBar
                android:id="@+id/reportProgress"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:id="@+id/reportStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Extracting medical report..."
                android:textSize="14sp"
                android:textColor="@color/on_surface_secondary" />
        </LinearLayout>

        <!-- ── Diagnosis Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/diagnosisCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_diagnosis">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <View android:layout_width="5dp" android:layout_height="match_parent"
                    android:background="@color/accent_diagnosis" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/diagnosis_title" android:textSize="13sp"
                        android:textColor="@color/accent_diagnosis" android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView android:id="@+id/diagnosisText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="15sp" android:textColor="@color/on_surface"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Medication Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/medicationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_medication">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <View android:layout_width="5dp" android:layout_height="match_parent"
                    android:background="@color/accent_medication" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/medication_title" android:textSize="13sp"
                        android:textColor="@color/accent_medication" android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView android:id="@+id/medicationText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="15sp" android:textColor="@color/on_surface"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Tests Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/testsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_tests">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <View android:layout_width="5dp" android:layout_height="match_parent"
                    android:background="@color/accent_tests" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/other_tests_title" android:textSize="13sp"
                        android:textColor="@color/accent_tests" android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView android:id="@+id/testsText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="15sp" android:textColor="@color/on_surface"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Follow-up Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/followupCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_followup">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <View android:layout_width="5dp" android:layout_height="match_parent"
                    android:background="@color/accent_followup" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/followup_title" android:textSize="13sp"
                        android:textColor="@color/accent_followup" android:textStyle="bold"
                        android:layout_marginBottom="6dp" />
                    <TextView android:id="@+id/followupText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="15sp" android:textColor="@color/on_surface"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── New Recording Button ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewRecording"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="🎙️  New Recording"
            android:textSize="15sp"
            android:visibility="gone"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/primary" />

    </LinearLayout>
</ScrollView>
